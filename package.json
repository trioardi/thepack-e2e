{
  "name": "daybook-qa-assessment",
  "version": "1.0.0",
  "description": "QA automation suite for the DayBook MERN journal app — Playwright E2E + Jest/Supertest API tests",
  "author": "Eric",
  "license": "MIT",
  "scripts": {
    "test": "npm run test:api && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:api": "jest --config api/jest.config.js --runInBand",
    "test:api:watch": "jest --config api/jest.config.js --watch",
    "postinstall": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.0"
  }
}
